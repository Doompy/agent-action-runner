{
  "name": "@agent-action-runner/nestjs",
  "version": "0.1.0",
  "description": "NestJS adapter for Agent Action Runner.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "npm run build --workspace @agent-action-runner/core --if-present",
    "build": "tsc -p tsconfig.build.json",
    "pretest": "npm run build --workspace @agent-action-runner/core --if-present",
    "test": "vitest run",
    "pretypecheck": "npm run build --workspace @agent-action-runner/core --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@agent-action-runner/core": "^0.1.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@agent-action-runner/core": "file:../core",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vitest": "^4.0.14"
  }
}

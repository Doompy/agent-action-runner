{
  "name": "agent-action-runner-shared-admin-ops-example",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "npm run build --workspace @agent-action-runner/core --if-present",
    "build": "tsc -p tsconfig.build.json",
    "pretest": "npm run build",
    "test": "vitest run src",
    "pretypecheck": "npm run build --workspace @agent-action-runner/core --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-action-runner/core": "file:../../packages/core",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vitest": "^4.0.14"
  }
}

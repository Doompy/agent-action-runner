{
  "name": "agent-action-runner-delivery-ops-example",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "main": "./dist/agent-runner.js",
  "types": "./dist/agent-runner.d.ts",
  "exports": {
    ".": {
      "types": "./dist/agent-runner.d.ts",
      "import": "./dist/agent-runner.js"
    }
  },
  "scripts": {
    "prebuild": "npm run build --workspace @agent-action-runner/express --if-present",
    "build": "tsc -p tsconfig.build.json",
    "pretest": "npm run build --workspace @agent-action-runner/express --if-present",
    "test": "vitest run src",
    "pretypecheck": "npm run build --workspace @agent-action-runner/express --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-action-runner/core": "file:../../packages/core",
    "@agent-action-runner/express": "file:../../packages/express",
    "@agent-action-runner/http": "file:../../packages/http",
    "express": "^5.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "vitest": "^4.0.14"
  }
}

{
  "name": "agent-action-runner",
  "version": "0.2.2",
  "private": true,
  "description": "Agent-safe action and workflow runner for TypeScript backends with schema validation, approval, audit, and MCP export support.",
  "license": "Apache-2.0",
  "author": "Doompy",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doompy/agent-action-runner.git"
  },
  "homepage": "https://github.com/Doompy/agent-action-runner#readme",
  "bugs": {
    "url": "https://github.com/Doompy/agent-action-runner/issues"
  },
  "keywords": [
    "typescript",
    "ai-agent",
    "llm",
    "workflow",
    "agent-workflow",
    "tool-calling",
    "mcp",
    "approval",
    "audit",
    "dry-run",
    "human-in-the-loop",
    "zod",
    "nestjs",
    "express",
    "fastify"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "pack:check": "npm pack --workspace @agent-action-runner/core --dry-run && npm pack --workspace @agent-action-runner/nestjs --dry-run && npm pack --workspace @agent-action-runner/http --dry-run && npm pack --workspace @agent-action-runner/express --dry-run && npm pack --workspace @agent-action-runner/fastify --dry-run",
    "pretest": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "pretypecheck": "npm run build --workspace @agent-action-runner/core --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}

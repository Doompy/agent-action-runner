{
  "name": "agent-action-runner",
  "version": "0.1.0",
  "private": true,
  "description": "A safe, application-native action and workflow runner for TypeScript backends.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "pretest": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "pretypecheck": "npm run build --workspace @agent-action-runner/core --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
